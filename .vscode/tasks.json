{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Kill StickFight.exe",
            "type": "shell",
            "command": "taskkill /F /IM StickFight.exe 2>nul || true",
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "label": "Build Stick Fight",
            "type": "shell",
            "command": "g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}/src/Main.cpp",
                "${workspaceFolder}/src/Player.cpp",
                "${workspaceFolder}/src/Enemy.cpp",
                "${workspaceFolder}/src/Render.cpp",
                "-o",
                "${workspaceFolder}/StickFight.exe",
                "-I",
                "C:/Users/abody/Desktop/sfml_game/SFML-3.0.0-windows-gcc-14.2.0-mingw-64-bit/SFML-3.0.0/include",
                "-L",
                "C:/Users/abody/Desktop/sfml_game/SFML-3.0.0-windows-gcc-14.2.0-mingw-64-bit/SFML-3.0.0/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Kill StickFight.exe",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}